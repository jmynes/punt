// PUNT - Kanban & Ticket Tracker Schema
// Learn more: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// Enums
// ============================================================================

enum TicketType {
  epic
  story
  task
  bug
  subtask
}

enum TicketPriority {
  lowest
  low
  medium
  high
  highest
  critical
}

enum SprintStatus {
  planning
  active
  completed
}

enum InvitationStatus {
  pending
  accepted
  expired
  revoked
}

enum InvitationRole {
  admin
  member
}

enum SprintEntryType {
  added
  carried_over
}

enum SprintExitStatus {
  completed
  carried_over
  removed
}

enum LinkType {
  blocks
  is_blocked_by
  relates_to
  duplicates
  is_duplicated_by
}

// ============================================================================
// Models
// ============================================================================

model User {
  id          String    @id @default(cuid())
  username    String    @unique
  email       String?   @unique
  name        String
  avatar      String?
  avatarColor String?   @map("avatar_color") // Custom background color for fallback avatar
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  lastLoginAt DateTime? @map("last_login_at")

  // Auth fields
  passwordHash      String?   @map("password_hash")
  passwordChangedAt DateTime? @map("password_changed_at") // For session invalidation after password change
  emailVerified     DateTime? @map("email_verified")
  isSystemAdmin     Boolean   @default(false) @map("is_system_admin")
  isActive          Boolean   @default(true) @map("is_active")

  // Two-factor authentication (TOTP)
  totpSecret        String?   @map("totp_secret") // Encrypted TOTP secret key
  totpEnabled       Boolean   @default(false) @map("totp_enabled") // Whether 2FA is active
  totpRecoveryCodes Json?     @map("totp_recovery_codes") // JSON array of hashed recovery codes

  // MCP API access
  mcpApiKey          String? @unique @map("mcp_api_key") // SHA-256 hash of API key for authentication
  mcpApiKeyEncrypted String?         @map("mcp_api_key_encrypted") // Encrypted raw API key for Claude CLI chat feature

  // Claude Chat API access
  anthropicApiKey        String? @map("anthropic_api_key") // User's own Anthropic API key for embedded chat
  chatProvider           String? @map("chat_provider") // Preferred chat provider: "anthropic" | "claude-cli"
  claudeSessionEncrypted String? @map("claude_session_encrypted") // Encrypted Claude CLI session credentials (experimental)
  enabledMcpServers      Json?   @map("enabled_mcp_servers") // JSON array of enabled MCP server names from Claude CLI credentials

  // Ticket relations
  assignedTickets  Ticket[]        @relation("Assignee")
  createdTickets   Ticket[]        @relation("Creator")
  watchingTickets  TicketWatcher[]

  // Project relations
  projects         ProjectMember[]

  // Activity
  comments         Comment[]
  ticketEdits      TicketEdit[]
  ticketActivities TicketActivity[]

  // Auth relations
  sessions                Session[]
  accounts                Account[]
  sentInvitations         Invitation[]
  passwordResetTokens     PasswordResetToken[]
  emailVerificationTokens EmailVerificationToken[]

  // Sprint relations
  completedSprints Sprint[] @relation("SprintCompleter")

  // Attachment relations
  uploadedAttachments Attachment[] @relation("Uploader")

  // Chat relations
  chatSessions ChatSession[]

  @@map("users")
}

// Auth.js Account model for OAuth providers (future-proofing)
model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

// Server-side session storage
model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  userAgent    String?  @map("user_agent")
  ipAddress    String?  @map("ip_address")
  createdAt    DateTime @default(now()) @map("created_at")
  lastActive   DateTime @default(now()) @map("last_active")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expires])
  @@map("sessions")
}

// Rate limiting for auth endpoints
model RateLimit {
  id          String   @id @default(cuid())
  identifier  String   // IP address or user ID
  endpoint    String   // e.g., "auth/login", "auth/register"
  count       Int      @default(1)
  windowStart DateTime @default(now()) @map("window_start")

  @@unique([identifier, endpoint])
  @@index([windowStart])
  @@map("rate_limits")
}

// Project invitation tokens (link-based)
model Invitation {
  id        String           @id @default(cuid())
  email     String
  role      InvitationRole   @default(member)
  token     String           @unique @default(cuid())
  expiresAt DateTime         @map("expires_at")
  status    InvitationStatus @default(pending)
  createdAt DateTime         @default(now()) @map("created_at")

  senderId  String?  @map("sender_id")
  sender    User?   @relation(fields: [senderId], references: [id], onDelete: SetNull)
  projectId String   @map("project_id")
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([email, projectId])
  @@index([projectId])
  @@index([token])
  @@index([email])
  @@map("invitations")
}

model Project {
  id          String   @id @default(cuid())
  name        String
  key         String   @unique // e.g., "PUNT", "PROJ"
  description String?
  color       String   @default("#6366f1")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  showAddColumnButton Boolean? @map("show_add_column_button") // null = inherit from global SystemSettings

  // Repository integration configuration
  repositoryUrl       String? @map("repository_url") // Repository URL (e.g., https://github.com/owner/repo)
  repositoryProvider  String? @map("repository_provider") // github, gitlab, bitbucket, gitea, codeberg, other
  localPath           String? @map("local_path") // Local filesystem path to the repo (for agent context)
  defaultBranch       String? @map("default_branch") // Default branch name (e.g., main, master)
  branchTemplate      String? @map("branch_template") // Branch naming template (e.g., "{type}/{key}-{slug}")
  agentGuidance       String? @map("agent_guidance") // Markdown instructions for AI agents working on this project
  monorepoPath        String? @map("monorepo_path") // Path within monorepo (e.g., "packages/frontend")
  environmentBranches Json?   @map("environment_branches") // JSON array of {id, environment, branchName} objects
  webhookSecret       String? @map("webhook_secret") // Secret for verifying GitHub/GitLab webhook signatures
  commitPatterns      Json?   @map("commit_patterns") // JSON array of custom commit patterns for webhook processing

  columns        Column[]
  tickets        Ticket[]
  members        ProjectMember[]
  labels         Label[]
  sprints        Sprint[]
  invitations    Invitation[]
  sprintSettings ProjectSprintSettings?
  roles          Role[]
  chatSessions   ChatSession[]

  @@map("projects")
}

model ProjectMember {
  id String @id @default(cuid())

  // Role relation (replaces old string role field)
  roleId String @map("role_id")
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  // Optional per-member permission overrides (additive to role permissions)
  // JSON array of permission strings, e.g., ["sprints.manage", "labels.manage"]
  overrides Json?

  userId    String  @map("user_id")
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId String  @map("project_id")
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([userId, projectId])
  @@index([projectId])
  @@index([roleId])
  @@map("project_members")
}

// Custom roles for granular permissions (Discord/Jira-style)
model Role {
  id          String  @id @default(cuid())
  name        String // "Owner", "Admin", "Moderator", "Member", "Viewer"
  color       String  @default("#6b7280") // For UI badge display
  description String? // Optional description of what this role can do

  // JSON array of permission strings, e.g., ["tickets.create", "tickets.manage_own"]
  permissions Json @default("[]")

  // Built-in roles (Owner, Admin, Member, Viewer) cannot be deleted
  isDefault Boolean @default(false) @map("is_default")

  // Position for display ordering (lower = higher rank)
  position Int @default(0)

  projectId String          @map("project_id")
  project   Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  members   ProjectMember[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([projectId, name])
  @@index([projectId])
  @@map("roles")
}

model Sprint {
  id        String       @id @default(cuid())
  name      String
  goal      String?
  startDate DateTime?    @map("start_date")
  endDate   DateTime?    @map("end_date")

  // Budget: expected story points capacity (optional)
  budget    Int?

  // Status replaces isActive: planning, active, completed
  status    SprintStatus @default(planning)

  // Completion tracking
  completedAt   DateTime? @map("completed_at")
  completedById String?   @map("completed_by_id")
  completedBy   User?     @relation("SprintCompleter", fields: [completedById], references: [id], onDelete: SetNull)

  // Completion metrics (calculated at close)
  completedTicketCount   Int? @map("completed_ticket_count")
  incompleteTicketCount  Int? @map("incomplete_ticket_count")
  completedStoryPoints   Int? @map("completed_story_points")
  incompleteStoryPoints  Int? @map("incomplete_story_points")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  projectId String   @map("project_id")
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tickets   Ticket[]

  // New relations
  ticketHistory    TicketSprintHistory[]
  carriedToTickets Ticket[] @relation("CarriedFrom")

  @@index([projectId])
  @@index([projectId, status])
  @@map("sprints")
}

model Column {
  id        String  @id @default(cuid())
  name      String
  icon      String?
  color     String?
  order     Int
  projectId String  @map("project_id")
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  tickets Ticket[]

  @@index([projectId])
  @@map("columns")
}

model Ticket {
  id     String @id @default(cuid())
  number Int    // Auto-increment per project (managed in app)

  // Core fields
  title       String
  description String? // Rich text / markdown body
  type        TicketType     @default(task)

  // Status & Priority
  priority TicketPriority @default(medium)
  order    Int            // Position within column

  // Estimation
  storyPoints Int?    @map("story_points")
  estimate    String? // Time estimate like "2h", "1d", "1w"

  // Dates
  startDate DateTime? @map("start_date")
  dueDate   DateTime? @map("due_date")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  // Resolution (for closed/done tickets)
  resolution   String? // Already Implemented, Done, Won't Fix, Duplicate, Cannot Reproduce, Incomplete, Won't Do
  resolvedAt   DateTime? @map("resolved_at") // When the ticket was resolved

  // Environment / Context
  environment  String? // e.g., "Production", "Staging", "Development"
  affectedVersion String? @map("affected_version")
  fixVersion   String?    @map("fix_version")

  // Relationships
  projectId  String  @map("project_id")
  project    Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  columnId   String  @map("column_id")
  column     Column  @relation(fields: [columnId], references: [id])

  // Users
  assigneeId String? @map("assignee_id")
  assignee   User?   @relation("Assignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  creatorId  String? @map("creator_id")
  creator    User?   @relation("Creator", fields: [creatorId], references: [id], onDelete: SetNull)

  // Sprint
  sprintId String? @map("sprint_id")
  sprint   Sprint? @relation(fields: [sprintId], references: [id], onDelete: SetNull)

  // Carryover tracking
  isCarriedOver         Boolean   @default(false) @map("is_carried_over")
  carriedFromSprintId   String?   @map("carried_from_sprint_id")
  carriedFromSprint     Sprint?   @relation("CarriedFrom", fields: [carriedFromSprintId], references: [id], onDelete: SetNull)
  carriedOverCount      Int       @default(0) @map("carried_over_count")

  // Sprint history
  sprintHistory         TicketSprintHistory[]

  // Parent ticket (for subtasks)
  parentId String?  @map("parent_id")
  parent   Ticket?  @relation("Subtasks", fields: [parentId], references: [id], onDelete: SetNull)
  subtasks Ticket[] @relation("Subtasks")

  // Many-to-many
  labels      Label[]
  watchers    TicketWatcher[]
  linkedFrom  TicketLink[] @relation("LinkedFrom")
  linkedTo    TicketLink[] @relation("LinkedTo")

  // Activity
  comments    Comment[]
  editHistory TicketEdit[]
  attachments Attachment[]
  activities  TicketActivity[]

  @@unique([projectId, number])
  @@index([projectId])
  @@index([columnId])
  @@index([assigneeId])
  @@index([sprintId])
  @@index([parentId])
  @@index([carriedFromSprintId])
  @@map("tickets")
}

// Watchers (CC users on a ticket)
model TicketWatcher {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now()) @map("created_at")

  ticketId String @map("ticket_id")
  ticket   Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  userId   String @map("user_id")
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([ticketId, userId])
  @@index([ticketId])
  @@index([userId])
  @@map("ticket_watchers")
}

// Linked tickets (blocks, is blocked by, relates to, duplicates, etc.)
model TicketLink {
  id       String   @id @default(cuid())
  linkType LinkType @map("link_type")

  fromTicketId String @map("from_ticket_id")
  fromTicket   Ticket @relation("LinkedFrom", fields: [fromTicketId], references: [id], onDelete: Cascade)
  toTicketId   String @map("to_ticket_id")
  toTicket     Ticket @relation("LinkedTo", fields: [toTicketId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  @@unique([fromTicketId, toTicketId, linkType])
  @@index([fromTicketId])
  @@index([toTicketId])
  @@map("ticket_links")
}

// Edit history for tickets
model TicketEdit {
  id        String   @id @default(cuid())
  field     String   // Which field was changed
  oldValue  String?  @map("old_value") // Previous value (JSON stringified if complex)
  newValue  String?  @map("new_value") // New value
  createdAt DateTime @default(now()) @map("created_at")

  ticketId String @map("ticket_id")
  ticket   Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  userId   String @map("user_id")
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@index([createdAt])
  @@map("ticket_edits")
}

// Comprehensive audit trail for ticket changes
model TicketActivity {
  id        String   @id @default(cuid())
  ticketId  String   @map("ticket_id")
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  userId    String?  @map("user_id")
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action    String   // created, updated, moved, assigned, labeled, sprint_changed, commented, etc.
  field     String?  // which field changed (for updates)
  oldValue  String?  @map("old_value") // previous value (stringified)
  newValue  String?  @map("new_value") // new value (stringified)
  groupId   String?  @map("group_id") // groups related changes (e.g., drag-move updates column + order)
  createdAt DateTime @default(now()) @map("created_at")

  @@index([ticketId, createdAt])
  @@index([userId])
  @@index([groupId])
  @@map("ticket_activities")
}

model Label {
  id        String  @id @default(cuid())
  name      String
  color     String
  projectId String  @map("project_id")
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  tickets Ticket[]

  @@unique([projectId, name])
  @@index([projectId])
  @@map("labels")
}

model Comment {
  id        String   @id @default(cuid())
  content   String   // Markdown content
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Track system-generated comments (e.g., MCP context logs)
  isSystemGenerated Boolean @default(false) @map("is_system_generated")
  source            String? // Optional source identifier (e.g., "mcp", "automation")

  ticketId String @map("ticket_id")
  ticket   Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  authorId String @map("author_id")
  author   User   @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@map("comments")
}

model Attachment {
  id        String   @id @default(cuid())
  filename  String
  mimeType  String   @map("mime_type")
  size      Int      // File size in bytes
  url       String   // Storage path or URL
  createdAt DateTime @default(now()) @map("created_at")

  ticketId String @map("ticket_id")
  ticket   Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  // Track who uploaded the attachment for ownership-based permission checks
  uploaderId String? @map("uploader_id")
  uploader   User?  @relation("Uploader", fields: [uploaderId], references: [id], onDelete: SetNull)

  @@index([ticketId])
  @@index([uploaderId])
  @@map("attachments")
}

// Track which sprints a ticket has been in for historical reporting
model TicketSprintHistory {
  id        String   @id @default(cuid())
  ticketId  String   @map("ticket_id")
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  sprintId  String   @map("sprint_id")
  sprint    Sprint   @relation(fields: [sprintId], references: [id], onDelete: Cascade)

  addedAt   DateTime @default(now()) @map("added_at")
  removedAt DateTime? @map("removed_at")

  entryType       SprintEntryType   @default(added) @map("entry_type")
  exitStatus      SprintExitStatus? @map("exit_status")

  carriedFromSprintId String? @map("carried_from_sprint_id")

  @@unique([ticketId, sprintId])
  @@index([ticketId])
  @@index([sprintId])
  @@map("ticket_sprint_history")
}

// Project-level sprint configuration
model ProjectSprintSettings {
  id                      String  @id @default(cuid())
  projectId               String  @unique @map("project_id")
  project                 Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  defaultSprintDuration   Int     @default(14) @map("default_sprint_duration") // days
  autoCarryOverIncomplete Boolean @default(true) @map("auto_carry_over_incomplete")
  doneColumnIds           Json    @default("[]") @map("done_column_ids") // JSON array

  // Default times for sprint start/end (HH:mm format, e.g., "09:00")
  defaultStartTime        String  @default("09:00") @map("default_start_time")
  defaultEndTime          String  @default("17:00") @map("default_end_time")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("project_sprint_settings")
}

// System-wide settings for file upload limits (singleton)
model SystemSettings {
  id        String   @id @default("system-settings")
  updatedAt DateTime @updatedAt @map("updated_at")
  updatedBy String?  @map("updated_by")

  // Branding settings
  appName          String  @default("PUNT") @map("app_name")
  logoUrl          String? @map("logo_url") // URL to uploaded logo image
  logoLetter       String  @default("P") @map("logo_letter")
  logoGradientFrom String  @default("#f59e0b") @map("logo_gradient_from")
  logoGradientTo   String  @default("#ea580c") @map("logo_gradient_to")

  // File upload limits (in MB)
  maxImageSizeMB          Int @default(10) @map("max_image_size_mb")
  maxVideoSizeMB          Int @default(100) @map("max_video_size_mb")
  maxDocumentSizeMB       Int @default(25) @map("max_document_size_mb")
  maxAttachmentsPerTicket Int @default(20) @map("max_attachments_per_ticket")

  // Allowed MIME types (native JSON arrays)
  allowedImageTypes    Json @default("[\"image/jpeg\",\"image/png\",\"image/gif\",\"image/webp\"]") @map("allowed_image_types")
  allowedVideoTypes    Json @default("[\"video/mp4\",\"video/webm\",\"video/ogg\",\"video/quicktime\"]") @map("allowed_video_types")
  allowedDocumentTypes Json @default("[\"application/pdf\",\"application/msword\",\"application/vnd.openxmlformats-officedocument.wordprocessingml.document\",\"application/vnd.ms-excel\",\"application/vnd.openxmlformats-officedocument.spreadsheetml.sheet\",\"text/plain\",\"text/csv\"]") @map("allowed_document_types")

  // Email provider configuration
  emailEnabled     Boolean @default(false) @map("email_enabled")
  emailProvider    String  @default("none") @map("email_provider") // none, smtp, resend, console
  emailFromAddress String  @default("") @map("email_from_address")
  emailFromName    String  @default("PUNT") @map("email_from_name")

  // SMTP settings (password stored in env var EMAIL_SMTP_PASSWORD)
  smtpHost     String  @default("") @map("smtp_host")
  smtpPort     Int     @default(587) @map("smtp_port")
  smtpUsername String  @default("") @map("smtp_username")
  smtpSecure   Boolean @default(true) @map("smtp_secure")

  // Email feature toggles
  emailPasswordReset Boolean @default(true) @map("email_password_reset")
  emailWelcome       Boolean @default(false) @map("email_welcome")
  emailVerification  Boolean @default(false) @map("email_verification")
  emailInvitations   Boolean @default(true) @map("email_invitations")

  // Board settings
  showAddColumnButton Boolean @default(true) @map("show_add_column_button")

  // Default role permissions for new projects (JSON object)
  // Keys: "Owner", "Admin", "Member", "Viewer"
  // Values: array of permission strings
  defaultRolePermissions Json? @map("default_role_permissions")

  // Repository configuration (global defaults)
  canonicalRepoUrl     String? @map("canonical_repo_url") // Upstream repository URL (e.g., https://github.com/owner/repo)
  repoHostingProvider  String? @map("repo_hosting_provider") // github, gitlab, bitbucket, gitea, codeberg, other
  forkRepoUrl          String? @map("fork_repo_url") // Fork repository URL (if different from canonical)

  // Agent configuration (global defaults)
  defaultBranchTemplate   String  @default("{type}/{key}-{slug}") @map("default_branch_template") // Default branch naming template
  defaultAgentGuidance    String? @map("default_agent_guidance") // Default Markdown instructions for AI agents

  // Default sprint times (system-wide defaults for new projects)
  defaultSprintStartTime  String  @default("09:00") @map("default_sprint_start_time") // HH:mm format
  defaultSprintEndTime    String  @default("17:00") @map("default_sprint_end_time") // HH:mm format

  @@map("system_settings")
}

// Password reset tokens (for forgot password flow)
model PasswordResetToken {
  id        String    @id @default(cuid())
  tokenHash String    @unique @map("token_hash") // SHA-256 hash of the token (never store plain token)
  userId    String    @map("user_id")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@index([userId])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

// Email verification tokens
model EmailVerificationToken {
  id        String   @id @default(cuid())
  tokenHash String   @unique @map("token_hash") // SHA-256 hash of the token
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  email     String   // Email being verified (may differ from current user email)
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@map("email_verification_tokens")
}

// Chat session for storing conversation history
model ChatSession {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Owner
  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Optional project context (for project-scoped conversations)
  projectId String?  @map("project_id")
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  messages ChatMessage[]

  @@index([userId])
  @@index([projectId])
  @@index([userId, updatedAt])
  @@map("chat_sessions")
}

// Individual chat messages within a session
model ChatMessage {
  id        String   @id @default(cuid())
  role      String // "user" | "assistant"
  content   String
  metadata  Json?  // JSON: tool calls, errors, etc.
  createdAt DateTime @default(now()) @map("created_at")

  sessionId String      @map("session_id")
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([sessionId, createdAt])
  @@map("chat_messages")
}
