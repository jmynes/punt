{
  "name": "punt",
  "version": "0.9.5",
  "private": true,
  "license": "AGPL-3.0-or-later",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "predev": "node scripts/check-deps.mjs",
    "dev": "next dev --turbopack",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:ci": "vitest run --coverage",
    "test:fuzz": "vitest run src/__tests__/fuzz",
    "db:generate": "prisma generate",
    "db:push": "prisma db push && tsx prisma/create-indexes.ts",
    "db:indexes": "tsx prisma/create-indexes.ts",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "db:import": "tsx -r tsconfig-paths/register scripts/import.ts",
    "db:seed-demo": "tsx prisma/seed-demo.ts",
    "db:generate-avatars": "tsx prisma/generate-avatars.ts",
    "prepare": "husky",
    "release": "node scripts/release.js",
    "setup": "tsx scripts/setup.ts",
    "mcp:login": "tsx scripts/mcp-login.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.92.0",
    "@auth/prisma-adapter": "^2.11.2",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/language-data": "^6.5.2",
    "@codemirror/state": "^6.6.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.41.1",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "@fortawesome/react-fontawesome": "^3.3.1",
    "@lexical/rich-text": "^0.35.0",
    "@mdxeditor/editor": "^3.55.0",
    "@mdxeditor/gurx": "^1.2.4",
    "@prisma/client": "^6.19.2",
    "@react-email/components": "^1.0.12",
    "@react-email/render": "^2.0.8",
    "@tanstack/react-query": "^5.100.9",
    "@tsparticles/confetti": "^3.9.1",
    "@tsparticles/engine": "^3.9.1",
    "@tsparticles/slim": "^3.9.1",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cm6-theme-basic-light": "^0.2.0",
    "cmdk": "^1.1.1",
    "codemirror": "^6.0.2",
    "date-fns": "^4.1.0",
    "dotenv": "^17.4.2",
    "file-type": "^22.0.1",
    "jszip": "^3.10.1",
    "lexical": "^0.35.0",
    "lucide-react": "^1.14.0",
    "next": "16.2.4",
    "next-auth": "5.0.0-beta.31",
    "next-themes": "^0.4.6",
    "nodemailer": "^7.0.13",
    "otplib": "^13.4.0",
    "prisma": "^6.19.2",
    "qrcode": "^1.5.4",
    "radix-ui": "^1.4.3",
    "react": "19.2.5",
    "react-colorful": "^5.6.1",
    "react-day-picker": "^9.14.0",
    "react-dom": "19.2.5",
    "react-easy-crop": "^5.5.7",
    "recharts": "^3.8.1",
    "resend": "^6.12.0",
    "sharp": "^0.34.5",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.12"
  },
  "pnpm": {
    "overrides": {
      "diff": ">=8.0.3"
    },
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "esbuild",
      "prisma"
    ]
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.2.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.7.0",
    "@types/nodemailer": "^7.0.10",
    "@types/pngjs": "^6.0.5",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.13",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/coverage-v8": "^4.1.5",
    "@vitest/ui": "^4.1.5",
    "fast-check": "^4.7.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^16.4.0",
    "msw": "^2.14.2",
    "pngjs": "^7.0.0",
    "tailwindcss": "^4.2.4",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6",
    "vitest": "^4.1.6"
  },
  "lint-staged": {
    "*.{js,ts,jsx,tsx,json}": [
      "biome check --write --no-errors-on-unmatched"
    ]
  }
}
